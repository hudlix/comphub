{
  "name": "@comphub/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --target=node18 --outfile=dist/index.js --external:express --external:cors --external:better-sqlite3",
    "start": "node dist/index.js",
    "typecheck": "tsc -p tsconfig.json",
    "lint": "eslint src"
  },
  "dependencies": {
    "@comphub/adapters-ports": "0.1.0",
    "@comphub/adapters-registry": "0.1.0",
    "@comphub/config": "0.1.0",
    "@comphub/core": "0.1.0",
    "better-sqlite3": "^11.3.0",
    "cors": "^2.8.5",
    "express": "^4.21.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.16.11",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.1"
  }
}
